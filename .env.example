# Opción A — Gateway (recomendado; expone /api/v1/... → microservicios):
SENTINELLA_API_URL=http://127.0.0.1:8080
#
# Opción B — Solo IAM (puerto 8081): el código usa automáticamente .../v1 en lugar de .../api/v1.
# Para el resto del dashboard hace falta el gateway; si tienes el gateway en otro puerto que no sea 8081,
# deja SENTINELLA_USE_IAM_DIRECT=false o define el prefijo a mano:
# SENTINELLA_API_PATH_PREFIX=/api/v1
#
# En Windows, si falla la conexión, prueba 127.0.0.1 en lugar de localhost (IPv4 vs IPv6).

# WebSocket STOMP del dashboard (mismo host que el gateway; ruta /v1/ws).
# Si enrutas solo al dashboard en otro puerto: ws://localhost:8085
NEXT_PUBLIC_WS_BASE_URL=ws://localhost:8080

# CORS en backend: app.cors.allowed-origins debe incluir http://localhost:3000 (u origen del front).
